// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String       @id @default(cuid())
  name          String?
  email         String?      @unique
  emailVerified DateTime?
  image         String?
  
  // QuantGuide specific fields
  currentStreak Int          @default(0)
  highestStreak Int          @default(0)
  lastActive    DateTime?
  
  accounts       Account[]
  sessions       Session[]
  submissions    Submission[]
  savedProblems  SavedProblem[]
  comments       Comment[]
  commentVotes   CommentVote[]
  problemRatings ProblemRating[]
  userBadges     UserBadge[]
  problemSets    ProblemSet[]
  reviewItems    ReviewItem[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Problem {
  id           String       @id @default(cuid())
  title        String
  description  String
  topic        String
  difficulty   String
  level        Int?         // QuantProf difficulty out of 10
  companies    String?      // Comma-separated company names
  source       String       @default("Quant Guide PDF")
  solution     String       // Store string, but parse numeric later, or store as numeric if possible. User said "ans should be numeric only" so solution can be just string representation of the number.
  fullSolution String?
  hint         String?
  createdAt    DateTime     @default(now())

  submissions    Submission[]
  savedProblems  SavedProblem[]
  comments       Comment[]
  ratings        ProblemRating[]
  setItems       ProblemSetItem[]
  reviewItems    ReviewItem[]
}

model SavedProblem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problemId String
  problem   Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)
  savedAt   DateTime @default(now())
  note      String?  @db.Text

  @@unique([userId, problemId])
}

model Submission {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  problemId      String
  problem        Problem  @relation(fields: [problemId], references: [id])
  isCorrect      Boolean
  manuallyMarked Boolean  @default(false)
  timeTaken      Int?     // seconds taken to solve
  submittedAt    DateTime @default(now())
}

model Comment {
  id        String        @id @default(cuid())
  text      String        @db.Text
  userId    String
  problemId String
  createdAt DateTime      @default(now())

  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem       @relation(fields: [problemId], references: [id], onDelete: Cascade)
  votes     CommentVote[]
}

model CommentVote {
  id        String  @id @default(cuid())
  userId    String
  commentId String
  value     Int     // +1 or -1

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  comment   Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)

  @@unique([userId, commentId])
}

model ProblemRating {
  id        String  @id @default(cuid())
  userId    String
  problemId String
  rating    Int     // 1-5

  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem   Problem @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}

model Badge {
  id          String      @id @default(cuid())
  name        String      @unique
  description String
  icon        String      // emoji or icon name
  criteria    String      // machine-readable criteria key
  threshold   Int         // numeric threshold for earning

  userBadges  UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model ProblemSet {
  id          String           @id @default(cuid())
  title       String
  description String?          @db.Text
  creatorId   String
  isOfficial  Boolean          @default(false)
  createdAt   DateTime         @default(now())

  creator     User             @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  items       ProblemSetItem[]
}

model ProblemSetItem {
  id        String     @id @default(cuid())
  setId     String
  problemId String
  order     Int

  set       ProblemSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  problem   Problem    @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([setId, problemId])
}

model ReviewItem {
  id          String   @id @default(cuid())
  userId      String
  problemId   String
  nextReview  DateTime
  interval    Int      @default(1) // days until next review
  easeFactor  Float    @default(2.5)
  repetitions Int      @default(0)
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  problem     Problem  @relation(fields: [problemId], references: [id], onDelete: Cascade)

  @@unique([userId, problemId])
}
